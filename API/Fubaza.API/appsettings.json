{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "System": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./Logs/log-.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 31,
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] {Message} {Properties}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "ApplicationName": "Fubaza"
    }
  },
  "MailSettings": {
    "From": "noreply@fubaza.com",
    "Host": "smtp.strato.de",
    "Port": 465,
    "UserName": "noreply@fubaza.com",
    "Password": "Fubaza@2024!!2024",
    "DisplayName": "Fubaza",
    "EnableVerification": true,
    "DefaultTo": "info@fubaza.com"
  },
  "AppSettings": {
    "BaseUrl": "https://fubuza-api.ahdus.de/"
  },
  "PersistenceSettings": {
    "UseMsSql": true,
    "UsePostgres": false,
    "connectionStrings": {
      //"mssql": "Data Source=DESKTOP-KDQ7S7N;Initial Catalog=Fubaza;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True;"
    }
  },
  "SerializationSettings": {
    "UseSystemTextJson": false,
    "UseNewtonsoftJson": true
  }
}
